# Variables de entorno de la aplicación web.
# Copia este archivo a `.env` y ajusta los valores, o configúralas en tu PaaS.

# Modo depuración de Flask. SIEMPRE 0 en producción (1 expone el debugger = RCE).
FLASK_DEBUG=0

# Forzar HTTPS y activar HSTS. Pon 1 en producción (detrás de un proxy con TLS).
FORCE_HTTPS=1

# Activa el recolector automático en segundo plano dentro del proceso web.
# Requerido en producción con gunicorn (que no ejecuta main()).
ONPE_RECOLECTOR=1

# Segundos entre cada recolección automática de la ONPE.
ONPE_INTERVALO=180

# Nivel máximo a recorrer: nacional | departamento | provincia | distrito.
ONPE_NIVEL_MAXIMO=departamento
